# ─── RedFlag CI Environment Variables ───────────────────
# Copy to .env and fill in your values.

# Frontend
# Required so the Vite frontend can talk to the FastAPI backend.
VITE_API_URL=http://localhost:8000

# AWS Infrastructure (MDA provides at Hour 2)
LAMBDA_FUNCTION_NAME=redflagci-scanner
DYNAMODB_TABLE_NAME=redflagci-scans
S3_BUCKET_NAME=redflagci-reports-184574354000
AWS_REGION=ap-south-1
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:184574354000:redflag-critical-alerts

# GitHub App (NV fills these)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_PRIVATE_KEY=
WEBHOOK_SECRET=

# Amazon Bedrock (NV fills these)
BEDROCK_MODEL_ID=claude-sonnet-4-20250514

FRONTEND_URL=http://localhost:5173
