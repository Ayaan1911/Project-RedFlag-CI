# ─── RedFlag CI Environment Variables ───────────────────
# Copy to .env and fill in your values.

# AWS Infrastructure (MDA provides at Hour 2)
API_GATEWAY_URL=https://{id}.execute-api.{region}.amazonaws.com/prod
LAMBDA_FUNCTION_NAME=redflagci-scanner
DYNAMODB_TABLE_NAME=redflagci-scans
S3_BUCKET_NAME=redflagci-reports
AWS_REGION=ap-south-1
SNS_TOPIC_ARN=

# GitHub App (NV fills these)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_PRIVATE_KEY=
WEBHOOK_SECRET=

# Amazon Bedrock (NV fills these)
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514

# Frontend
FRONTEND_URL=http://localhost:5173
